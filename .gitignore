# -----------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------
# Python
# -----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# -----------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
secrets/

# -----------------------------------------------------------
# Docker
# -----------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------
# Logs
# -----------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------
# Session / Runtime Data
# -----------------------------------------------------------
session-data/
*.session
*.pid

# -----------------------------------------------------------
# Test / Coverage
# -----------------------------------------------------------
coverage/
htmlcov/
.coverage

# -----------------------------------------------------------
