# ============================================================
# kimi-agent 服务端 Agent 框架环境变量配置
# ============================================================
# 1. 复制本文件为 .env:  cp .env.example .env
# 2. 编辑 .env 文件，填入实际的 API Key 和配置
# 3. 运行: docker-compose up -d
# ============================================================

# -----------------------------------------------------------
# LLM Provider 配置（至少配置一个）
# -----------------------------------------------------------

# Kimi / Moonshot (推荐)
KIMI_API_KEY=sk-your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL_NAME=kimi-k2
KIMI_MODEL_MAX_CONTEXT_SIZE=131072

# OpenAI / OpenAI 兼容端点
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 默认 LLM Provider (kimi / openai / anthropic)
LLM_PROVIDER=kimi

# 是否启用 thinking 模式
LLM_THINKING=false

# 采样温度 (0.0 - 2.0)
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------
# Web 服务安全配置
# -----------------------------------------------------------

# Web UI 访问端口
KIMI_WEB_PORT=5494

# 会话认证 Token（必须设置，否则任何人可访问）
# 建议使用强随机字符串: openssl rand -hex 32
KIMI_WEB_SESSION_TOKEN=change-me-to-a-random-token

# 允许的跨域来源 (逗号分隔，* 表示允许所有)
KIMI_WEB_ALLOWED_ORIGINS=*

# 是否强制校验 Origin 头
KIMI_WEB_ENFORCE_ORIGIN=false

# 是否限制敏感 API (生产环境建议开启)
KIMI_WEB_RESTRICT_SENSITIVE_APIS=false

# 公开文件访问最大路径深度
KIMI_WEB_MAX_PUBLIC_PATH_DEPTH=6

# 是否仅允许局域网访问
KIMI_WEB_LAN_ONLY=false

# -----------------------------------------------------------
# Sandbox 容器镜像配置
# -----------------------------------------------------------

# Sandbox 镜像名称 (构建后生成)
SANDBOX_IMAGE=kimi-agent-sandbox:latest

# 容器内工作目录
SANDBOX_WORK_DIR=/app

# 最大同时运行的 session 容器数
MAX_SESSION_CONTAINERS=50

# -----------------------------------------------------------
# Session 容器资源限制
# -----------------------------------------------------------

# CPU 核心数限制
SANDBOX_CPU_LIMIT=2

# 内存限制 (例如: 512m, 2g, 4g)
SANDBOX_MEMORY_LIMIT=4g

# 磁盘限制 (overlayfs)
SANDBOX_DISK_LIMIT=10g

# 最大进程数限制
SANDBOX_PID_LIMIT=1000

# 容器自动销毁超时 (秒, 默认 24 小时)
SANDBOX_TIMEOUT_SECONDS=86400

# -----------------------------------------------------------
# 功能开关
# -----------------------------------------------------------

# 是否启用浏览器自动化
ENABLE_BROWSER=true

# 是否启用 Jupyter Kernel
ENABLE_JUPYTER=true

# 是否启用 Shell 沙箱
ENABLE_SHELL_SANDBOX=true

# 是否拦截危险命令 (rm -rf /, mkfs, dd 等)
BLOCK_DANGEROUS_COMMANDS=true

# -----------------------------------------------------------
# 自定义扩展 Skill 目录
# -----------------------------------------------------------

# 宿主机上自定义 Skill 目录的绝对路径（可选）
# 设置后，该目录会被挂载到每个 Sandbox 容器的 ~/.config/agents/skills
# Skill 目录结构：每个子目录是一个 skill，目录内包含 SKILL.md 文件
# 示例: CUSTOM_SKILLS_HOST_PATH=/home/user/kimi-agent/custom-skills
CUSTOM_SKILLS_HOST_PATH=

# -----------------------------------------------------------
# HuggingFace Cache 共享
# -----------------------------------------------------------

# 宿主机上 HuggingFace Cache 目录的绝对路径（可选）
# 设置后，该目录会被挂载到每个 Sandbox 容器的 /root/.cache/huggingface
# 同时 HF_HOME 环境变量会被自动设置为挂载点，让 transformers/datasets
# 等库自动复用宿主机的模型缓存，避免每次启动 session 都重新下载
# 示例: HF_CACHE_HOST_PATH=/home/user/.cache/huggingface
HF_CACHE_HOST_PATH=
